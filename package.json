{
  "name": "annoying-claude",
  "version": "0.1.0",
  "description": "Desktop Goose, but with the Claude Code mascot — an annoying companion that wanders your screen and fakes AI agent hallucinations.",
  "main": "out/main/index.js",
  "author": "Dylan Flandrin",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package": "electron-vite build && electron-builder --win --x64",
    "package:portable": "electron-vite build && electron-builder --win portable --x64"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "howler": "^2.2.4"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "@types/node": "^22.10.5",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
